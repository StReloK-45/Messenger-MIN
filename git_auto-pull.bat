@echo off
:: ============================================
:: Git Auto Pull
:: ============================================
:: Автоматический pull репозитория мессенджера MIN при запуске системы
:: ============================================
:: ИНСТРУКЦИЯ ПО НАСТРОЙКЕ:
:: ============================================
:: 1. Открыть командную строку и перейти в папку с репозиторием
:: 2. Выполнить: git config --global credential.helper wincred
:: 3. Выполнить: git pull (ввести логин и пароль один раз — Git запомнит)
:: 4. Нажать Win+R, ввести "shell:startup" и нажать Enter
:: 5. В открывшуюся папку перетащить ЯРЛЫК этого скрипта (не сам файл!)
:: ============================================
:: Скрипт написан CrazyDrozd, дата: 06.05.2026
:: ============================================

:: Скрытый запуск .bat скрипта
if not "%1"=="hide" (
    start /min "" "%~f0" hide
    exit
)

:: Переход в папку со скриптом 
cd /d "%~dp0"

:: Переменная: путь git для работы с её командами 
:: [ВАЖНО!] Нужно убедиться что у вас правильный путь к файлу с Git с помощью команды консоли "where git"
set GIT="C:\Program Files\Git\cmd\git.exe"

:: Переменная: файл для логов
set LOGFILE="%~dp0auto-pull_log.txt" 

:: Пишем дату и время
echo [%date% %time%] ------------------------------ >> %LOGFILE%

:: Запуск pull и отладка в логи
%GIT% pull >> %LOGFILE% 2>&1

:: Проверка результата
if %errorlevel% equ 0 (
    echo [%date% %time%] Status: SUCCESS >> %LOGFILE%
) else (
    echo [%date% %time%] Status: ERROR (code %errorlevel%) >> %LOGFILE%
)

exit /b 0
